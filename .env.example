# Jira source
JIRA_MODE=mock
# JIRA_MODE=real
# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=your-jira-token
# JIRA_ACCEPTANCE_CRITERIA_FIELD=customfield_12345

# Test generation
# Use rule for deterministic local demos, openai for true LLM-generated tests.
TEST_GENERATION_MODE=rule
# TEST_GENERATION_MODE=openai
# OPENAI_API_KEY=your-openai-key
# OPENAI_MODEL=gpt-5.2

# API under test
APP_BASE_URL=https://restful-booker.herokuapp.com
# APP_API_TOKEN is only used by the older order-api demo placeholders.
APP_API_TOKEN=fake-app-token

# Live API SSL handling. Keep true normally. Set false only for local/corporate proxy demo issues.
VERIFY_SSL=true
